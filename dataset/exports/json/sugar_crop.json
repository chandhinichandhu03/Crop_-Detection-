    "pests": [
      {
        "id": 11,
        "pest_name": "Yellow Stem Borer (Rice)",
        "scientific_name": "Scirpophaga incertulas",
        "pest_category": "Chewing_Caterpillars",
        "damage_type": "Stem boring",
        "control": {
          "organic": "Clip leaf tips of transplanted seedlings (removes egg masses); light traps; pheromone traps; release Trichogramma japonicum",
          "chemical": "Cartap hydrochloride 4G granules (25 kg/ha in standing water), Chlorpyrifos 20% EC (2ml/L), Carbofuran 3G, Fipronil 0.3G",
          "biological": "Trichogramma japonicum (egg parasitoid, 1 lakh/ha at 10-day intervals), Tetrastichus schoenobii, Telenomus rowani"
        }
      },
      {
        "id": 14,
        "pest_name": "White Grubs (Chafer Beetles)",
        "scientific_name": "Holotrichia consanguinea, Leucopholis lepidophora (multiple spp.)",
        "pest_category": "Soil_Pests",
        "damage_type": "Root feeding (grubs); adult defoliation",
        "control": {
          "organic": "Metarhizium anisopliae fungus (1×10⁹ spores/ml) soil application; ploughing to expose and destroy grubs; light traps for adults; neem cake 250 kg/ha",
          "chemical": "Chlorpyrifos 20% EC (5L/ha) soil incorporation before planting; Carbofuran 3G (25 kg/ha); Phorate 10G; Imidacloprid seed treatment",
          "biological": "Metarhizium anisopliae, Beauveria bassiana soil inoculants; Heterorhabditis bacteriophora (entomopathogenic nematode)"
        }
      },
      {
        "id": 9,
        "pest_name": "Fall Armyworm",
        "scientific_name": "Spodoptera frugiperda",
        "pest_category": "Chewing_Caterpillars",
        "damage_type": "Leaf and whorl feeding; ear damage",
        "control": {
          "organic": "Bt-kurstaki or Bt-aizawai spray; fall armyworm pheromone traps; sand+soil in whorl (suffocates larvae); egg mass and larvae hand collection",
          "chemical": "Emamectin benzoate 5% SG (0.4g/L into whorl), Chlorantraniliprole (Coragen), Spinetoram, Lambda-cyhalothrin (adult moths)",
          "biological": "Telenomus remus (egg parasitoid), Cotesia icipe, Coccygomimus turionellae, Metarhizium rileyi, NPV (Nuclear Polyhedrosis Virus)"
        }
      }
