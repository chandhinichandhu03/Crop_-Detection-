      },
      "planting": {
        "seed_rate": "",
        "spacing": ""
      },
      "irrigation": {
        "method": "Drip irrigation most efficient; furrow also used",
        "critical_stages": "Establishment, grand growth period (3-9 months)",
        "water_requirement_mm": "1500-2500mm total"
      },
      "fertilization": {
        "npk": "N280-P120-K160 planted crop; N240-P80-K140 ratoon",
        "schedule": "Basal: 50%P+50%K; N split every 45 days (5 splits)"
      },
      "harvesting": {
        "maturity_indicator": "12-14 months for plant crop; 10-12 months for ratoon; CCS (Commercial Cane Sugar) > 10%",
        "method": "Manual harvesting (topped and detrashed) or mechanical harvester",
        "yield_per_ha": "70-100 t/ha cane; 8-11 t/ha sugar"
      }
