    "cultivation": {
      "climate": {
        "type": "Cool temperate to sub-tropical",
        "temp_optimum": "Germination 3-25°C; optimal growth 15-21°C; grain fill 20-25°C",
        "rainfall": "375-875mm (rabi / winter crop; relies on residual moisture and irrigation)"
      },
      "soil": {
        "type": "Well-drained fertile loam or clay-loam soils",
        "ph_range": "6.0-7.5",
        "special_requirements": "Good aeration; moderate to high organic matter"
      },
      "planting": {
        "seed_rate": "100-125 kg/ha (timely sown); 125-150 kg/ha (late sown)",
        "spacing": "22.5 cm row spacing (seed drill); broadcast is less preferred"
      },
      "irrigation": {
        "method": "Flood/furrow; drip/sprinkler for water efficiency",
        "critical_stages": "CRI (Crown Root Initiation at 21 DAS), Tillering, Jointing, Flowering, Grain filling",
        "water_requirement_mm": "400-500mm total"
      },
      "fertilization": {
        "npk": "N120-P60-K40 for HYV; N150 with S15 for better protein",
        "schedule": "Basal: 50%N+100%P+100%K; Topdressing: 25%N at CRI + 25%N at tillering"
      },
      "harvesting": {
        "maturity_indicator": "Straw golden yellow; grain hard and moisture 18-20%",
        "method": "Combine harvester or manual harvesting + threshing",
        "yield_per_ha": "3-6 t/ha irrigated; 1.5-2.5 t/ha rainfed"
      }
    },
    "diseases": [
      {
        "id": 16,
        "disease_name": "Stem Rust (Black Rust)",
        "pathogen_name": "Puccinia graminis f. sp. tritici",
        "disease_type": "Fungal",
